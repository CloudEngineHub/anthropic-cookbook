{
  "name": "cloudrepl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "cp node_modules/@jitl/quickjs-wasmfile-release-sync/dist/emscripten-module.wasm src/quickjs.wasm",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --name cloudrepl-${SAFEUSER:-$(whoami)}",
    "deploy:shared": "wrangler deploy",
    "tail": "wrangler tail --name cloudrepl-${SAFEUSER:-$(whoami)}",
    "types": "wrangler types"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "https://app.stainless.com/pkg/s/anthropic-typescript/390776956d4f4fca9f3cad0eda32a4c59467bca2/dist.tar.gz",
    "quickjs-emscripten-core": "^0.31.0",
    "@jitl/quickjs-wasmfile-release-sync": "^0.31.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.76.0"
  }
}
